# Tacklines marketing site
# These blocks are appended to the server's main Caddyfile.
# TLS config (tls_config snippet) is defined in the server's root Caddyfile.
# Deploy: npm run build, copy dist/ to /opt/tacklines/www, reload caddy.

www.tacklines.com {
	import tls_config
	redir https://tacklines.com{uri} permanent
}

tacklines.com {
	import tls_config
	encode gzip

	root * /opt/tacklines/www
	try_files {path} /index.html
	file_server
}
